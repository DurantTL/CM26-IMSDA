# Ignore all files by default
**

# Whitelist Google Apps Script files in root
!appsscript.json
!*.gs
!*.html

# Explicitly ignore directories to prevent accidental inclusion via whitelists
pwa/
node_modules/
tests/
verification/
.git/
.github/

# Ignore project metadata files
README.md
CLAUDE.md
SUGGESTIONS.md
PERFORMANCE_BASELINE.md
package.json
package-lock.json
server.js
.clasp.json
.claspignore
.gitignore
